{
  "dependencies": {
    "@wopr-network/plugin-types": "^0.9.0",
    "ws": "^8.16.0"
  },
  "description": "Deepgram STT provider using nova-3 model",
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/node": "^25.3.2",
    "@types/ws": "^8.5.10",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "name": "@wopr-network/wopr-plugin-voice-deepgram-stt",
  "scripts": {
    "build": "tsc",
    "check": "biome check index.ts && tsc --noEmit",
    "dev": "tsc -w",
    "format": "biome format --write index.ts",
    "lint": "biome check index.ts",
    "lint:fix": "biome check --fix index.ts",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "keywords": ["wopr-plugin"],
  "type": "module",
  "version": "1.0.0",
  "wopr": {
    "plugin": {
      "category": "voice",
      "description": "Cloud STT using Deepgram's nova-3 model",
      "icon": "microphone",
      "install": [],
      "name": "voice-deepgram-stt",
      "tags": [
        "voice",
        "stt",
        "deepgram",
        "cloud",
        "transcription"
      ],
      "requires": {
        "env": [
          "DEEPGRAM_API_KEY"
        ]
      },
      "provides": {
        "capabilities": [
          {
            "type": "stt",
            "name": "deepgram-stt"
          }
        ]
      },
      "capabilities": ["provider"],
      "lifecycle": {
        "init": true,
        "shutdown": true,
        "shutdownBehavior": "graceful"
      },
      "configSchema": {
        "type": "object",
        "properties": {
          "apiKey": {
            "type": "string",
            "description": "Deepgram API key",
            "secret": true,
            "setupFlow": "paste"
          },
          "model": {
            "type": "string",
            "description": "Deepgram model (default: nova-3)",
            "default": "nova-3",
            "enum": [
              "nova-3",
              "nova-2",
              "nova",
              "enhanced",
              "base"
            ]
          },
          "language": {
            "type": "string",
            "description": "Language code (default: en)",
            "default": "en"
          }
        },
        "required": []
      },
      "type": "stt"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "release": {
    "extends": "@wopr-network/semantic-release-config"
  }
}
